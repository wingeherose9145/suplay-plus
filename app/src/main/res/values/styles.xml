<resources>
    <style name="FiftyToneButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        
        <item name="android:layout_margin">3dp</item>
        
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        
        <item name="android:backgroundTint">#000000</item>
        <item name="android:textColor">#FF9800</item>
        
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/geek_font_bold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">#2C2C2C</item>
        <item name="strokeWidth">1.2dp</item>
        <item name="rippleColor">#40FF9800</item>
    </style>
</resources>
