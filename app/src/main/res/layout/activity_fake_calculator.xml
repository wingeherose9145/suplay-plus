<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="10dp">

    <!-- 顶部显示区 -->
    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="end|center_vertical"
        android:textSize="26sp"
        android:textColor="#FFFFFF"
        android:padding="16dp"
        android:background="#111111"
        android:maxLines="1" />

    <!-- 按钮区域 -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="4"
        android:rowCount="12"
        android:paddingTop="12dp">

        <!-- ===== 第一行 ===== -->
        <Button style="@style/CalcBtn" android:text="sin" android:id="@+id/btnSin"/>
        <Button style="@style/CalcBtn" android:text="cos" android:id="@+id/btnCos"/>
        <Button style="@style/CalcBtn" android:text="tan" android:id="@+id/btnTan"/>
        <Button style="@style/CalcBtn" android:text="π" android:id="@+id/btnPi"/>

        <!-- ===== 第二行 ===== -->
        <Button style="@style/CalcBtn" android:text="log" android:id="@+id/btnLog"/>
        <Button style="@style/CalcBtn" android:text="ln" android:id="@+id/btnLn"/>
        <Button style="@style/CalcBtn" android:text="e" android:id="@+id/btnE"/>
        <Button style="@style/CalcBtn" android:text="√" android:id="@+id/btnSqrt"/>

        <!-- ===== 第三行 ===== -->
        <Button style="@style/CalcBtn" android:text="7" android:id="@+id/btn7"/>
        <Button style="@style/CalcBtn" android:text="8" android:id="@+id/btn8"/>
        <Button style="@style/CalcBtn" android:text="9" android:id="@+id/btn9"/>
        <Button style="@style/CalcBtn" android:text="÷" android:id="@+id/btnDivide"/>

        <!-- ===== 第四行 ===== -->
        <Button style="@style/CalcBtn" android:text="4" android:id="@+id/btn4"/>
        <Button style="@style/CalcBtn" android:text="5" android:id="@+id/btn5"/>
        <Button style="@style/CalcBtn" android:text="6" android:id="@+id/btn6"/>
        <Button style="@style/CalcBtn" android:text="×" android:id="@+id/btnMultiply"/>

        <!-- ===== 第五行 ===== -->
        <Button style="@style/CalcBtn" android:text="1" android:id="@+id/btn1"/>
        <Button style="@style/CalcBtn" android:text="2" android:id="@+id/btn2"/>
        <Button style="@style/CalcBtn" android:text="3" android:id="@+id/btn3"/>
        <Button style="@style/CalcBtn" android:text="-" android:id="@+id/btnMinus"/>

        <!-- ===== 第六行 ===== -->
        <Button style="@style/CalcBtn" android:text="0" android:id="@+id/btn0"/>
        <Button style="@style/CalcBtn" android:text="." android:id="@+id/btnDot"/>
        <Button style="@style/CalcBtn" android:text="=" android:id="@+id/btnEqual"/>
        <Button style="@style/CalcBtn" android:text="+" android:id="@+id/btnPlus"/>

        <!-- ===== 第七行 ===== -->
        <Button style="@style/CalcBtn" android:text="abs" android:id="@+id/btnAbs"/>
        <Button style="@style/CalcBtn" android:text="x²" android:id="@+id/btnPow"/>
        <Button style="@style/CalcBtn" android:text="!" android:id="@+id/btnFact"/>
        <Button style="@style/CalcBtn" android:text="C" android:id="@+id/btnClear"/>

        <!-- ===== 第八行 ===== -->
        <Button
    android:id="@+id/btnMod"
    style="@style/CalcBtn"
    android:text="mod"/>

<Button
    android:id="@+id/btnRad"
    style="@style/CalcBtn"
    android:text="rad"/>

<Button
    android:id="@+id/btnDeg"
    style="@style/CalcBtn"
    android:text="deg"/>

<Button
    android:id="@+id/btnLn2"
    style="@style/CalcBtn"
    android:text="ln2"/>


<!-- ===== 第九行 ===== -->
<Button
    android:id="@+id/btnAsin"
    style="@style/CalcBtn"
    android:text="sin⁻¹"/>

<Button
    android:id="@+id/btnAcos"
    style="@style/CalcBtn"
    android:text="cos⁻¹"/>

<Button
    android:id="@+id/btnAtan"
    style="@style/CalcBtn"
    android:text="tan⁻¹"/>

<Button
    android:id="@+id/btnPhi"
    style="@style/CalcBtn"
    android:text="φ"/>


<!-- ===== 第十行 ===== -->
<Button
    android:id="@+id/btnPowY"
    style="@style/CalcBtn"
    android:text="xʸ"/>

<Button
    android:id="@+id/btnTenPow"
    style="@style/CalcBtn"
    android:text="10ˣ"/>

<Button
    android:id="@+id/btnEPow"
    style="@style/CalcBtn"
    android:text="eˣ"/>

<Button
    android:id="@+id/btnAbsX"
    style="@style/CalcBtn"
    android:text="|x|"/>


<!-- ===== 第十一行 ===== -->
<Button
    android:id="@+id/btnSigma"
    style="@style/CalcBtn"
    android:text="Σ"/>

<Button
    android:id="@+id/btnIntegral"
    style="@style/CalcBtn"
    android:text="∫"/>

<Button
    android:id="@+id/btnDiff"
    style="@style/CalcBtn"
    android:text="d/dx"/>

<Button
    android:id="@+id/btnInf"
    style="@style/CalcBtn"
    android:text="∞"/>


<!-- ===== 第十二行 ===== -->
<Button
    android:id="@+id/btnMatrix"
    style="@style/CalcBtn"
    android:text="matrix"/>

<Button
    android:id="@+id/btnVector"
    style="@style/CalcBtn"
    android:text="vector"/>

<Button
    android:id="@+id/btnRand"
    style="@style/CalcBtn"
    android:text="rand"/>

<Button
    android:id="@+id/btnClose"
    style="@style/CalcBtn"
    android:text="CLOSE"/>

    </GridLayout>

</LinearLayout>
