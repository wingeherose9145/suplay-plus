<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="10dp">

    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:gravity="end|center_vertical"
        android:textSize="26sp"
        android:textColor="#FFFFFF"
        android:padding="16dp"
        android:background="#111111"
        android:maxLines="1" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="4"
        android:rowCount="12"
        android:paddingTop="12dp">

        <Button style="@style/CalcBtn" android:id="@+id/btn7" android:text="7" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn8" android:text="8" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn9" android:text="9" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnDivide" android:text="÷" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btn4" android:text="4" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn5" android:text="5" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn6" android:text="6" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnMultiply" android:text="×" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btn1" android:text="1" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn2" android:text="2" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btn3" android:text="3" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnMinus" android:text="-" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btn0" android:text="0" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnDot" android:text="." android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnEqual" android:text="=" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnPlus" android:text="+" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnSin" android:text="S" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnCos" android:text="C" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnTan" android:text="T" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnRad" android:text="R" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnAsin" android:text="S⁻" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnAcos" android:text="C⁻" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnAtan" android:text="T⁻" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnDeg" android:text="D" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnLog" android:text="L" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnLn" android:text="N" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnLn2" android:text="N₂" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnMod" android:text="%" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnPow" android:text="x²" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnPowY" android:text="xʸ" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnTenPow" android:text="1⁰" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnEPow" android:text="eˣ" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnSigma" android:text="Σ" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnIntegral" android:text="∫" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnDiff" android:text="∂" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnSqrt" android:text="√" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnAbs" android:text="A" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnAbsX" android:text="|x|" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnFact" android:text="!" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnInf" android:text="∞" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnPi" android:text="π" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnE" android:text="e" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnPhi" android:text="φ" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnRand" android:text="?" android:textColor="#FFFFFF"/>

        <Button style="@style/CalcBtn" android:id="@+id/btnMatrix" android:text="M" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnVector" android:text="V" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnClear" android:text="C" android:textColor="#FFFFFF"/>
        <Button style="@style/CalcBtn" android:id="@+id/btnClose" android:text="X" android:textColor="#FFFFFF"/>

    </GridLayout>
</LinearLayout>
