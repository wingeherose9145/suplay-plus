<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="12dp">

    <TextView
        android:id="@+id/display"
        android:layout_width="match_parent"
        android:layout_height="110dp"
        android:layout_marginBottom="16dp"
        android:background="#151515"
        android:gravity="bottom|end"
        android:maxLines="1"
        android:padding="16dp"
        android:textColor="#FFFFFF"
        android:textSize="40sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:columnCount="4"
        android:rowCount="12">

        <Button android:id="@+id/btnSin" style="@style/CalcBtn" android:text="sin"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnCos" style="@style/CalcBtn" android:text="cos"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnTan" style="@style/CalcBtn" android:text="tan"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnPi" style="@style/CalcBtn" android:text="π"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btnLog" style="@style/CalcBtn" android:text="log"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnLn" style="@style/CalcBtn" android:text="ln"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnE" style="@style/CalcBtn" android:text="e"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnSqrt" style="@style/CalcBtn" android:text="√"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btn7" style="@style/CalcBtn" android:text="7"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn8" style="@style/CalcBtn" android:text="8"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn9" style="@style/CalcBtn" android:text="9"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnDivide" style="@style/CalcBtn" android:text="÷"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp"/>

        <Button android:id="@+id/btn4" style="@style/CalcBtn" android:text="4"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn5" style="@style/CalcBtn" android:text="5"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn6" style="@style/CalcBtn" android:text="6"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnMultiply" style="@style/CalcBtn" android:text="×"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp"/>

        <Button android:id="@+id/btn1" style="@style/CalcBtn" android:text="1"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn2" style="@style/CalcBtn" android:text="2"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btn3" style="@style/CalcBtn" android:text="3"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnMinus" style="@style/CalcBtn" android:text="-"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp"/>

        <Button android:id="@+id/btn0" style="@style/CalcBtn" android:text="0"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnDot" style="@style/CalcBtn" android:text="."
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp" android:textStyle="bold"/>
        <Button android:id="@+id/btnEqual" style="@style/CalcBtn" android:text="="
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp"/>
        <Button android:id="@+id/btnPlus" style="@style/CalcBtn" android:text="+"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="26sp"/>

        <Button android:id="@+id/btnAbs" style="@style/CalcBtn" android:text="abs"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnPow" style="@style/CalcBtn" android:text="x²"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnFact" style="@style/CalcBtn" android:text="!"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnClear" style="@style/CalcBtn" android:text="C"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btnMod" style="@style/CalcBtn" android:text="mod"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnRad" style="@style/CalcBtn" android:text="rad"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnDeg" style="@style/CalcBtn" android:text="deg"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnLn2" style="@style/CalcBtn" android:text="ln2"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btnAsin" style="@style/CalcBtn" android:text="s⁻¹"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnAcos" style="@style/CalcBtn" android:text="c⁻¹"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnAtan" style="@style/CalcBtn" android:text="t⁻¹"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnPhi" style="@style/CalcBtn" android:text="φ"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btnPowY" style="@style/CalcBtn" android:text="xʸ"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnTenPow" style="@style/CalcBtn" android:text="10ˣ"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnEPow" style="@style/CalcBtn" android:text="eˣ"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnAbsX" style="@style/CalcBtn" android:text="|x|"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btnSigma" style="@style/CalcBtn" android:text="Σ"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnIntegral" style="@style/CalcBtn" android:text="∫"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnDiff" style="@style/CalcBtn" android:text="∂x"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnInf" style="@style/CalcBtn" android:text="∞"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

        <Button android:id="@+id/btnMatrix" style="@style/CalcBtn" android:text="[M]"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnVector" style="@style/CalcBtn" android:text="[V]"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnRand" style="@style/CalcBtn" android:text="Rnd"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>
        <Button android:id="@+id/btnClose" style="@style/CalcBtn" android:text="OFF"
            android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1"
            android:layout_margin="5dp" android:backgroundTint="#FF9800" android:textColor="#FFFFFF" android:textSize="22sp"/>

    </GridLayout>

</LinearLayout>
